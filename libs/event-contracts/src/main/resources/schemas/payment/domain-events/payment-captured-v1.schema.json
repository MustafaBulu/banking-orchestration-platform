{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://payment-platform.local/schemas/payment.domain.events.PaymentCaptured/1",
  "title": "PaymentCaptured v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "aggregateId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "data"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "aggregateId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "const": "PaymentCaptured"
    },
    "eventVersion": {
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "customerId",
        "amount",
        "currency"
      ],
      "properties": {
        "customerId": {
          "type": "string",
          "minLength": 1
        },
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    }
  }
}
